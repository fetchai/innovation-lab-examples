# ── ASI:One (LLM) ─────────────────────────────────────────────────────────────
# Get your key at https://asi1.ai
ASI1_API_KEY=your_asi1_api_key_here

# ── Google APIs ───────────────────────────────────────────────────────────────
# Used for geocoding, Places lookup, Static Maps, and Place Photos.
# Enable Maps JavaScript API, Places API, and Static Maps API in Google Cloud.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── YouTube Data API ──────────────────────────────────────────────────────────
# Used to fetch video transcripts. Enable at https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Agentverse / Fetch.ai ─────────────────────────────────────────────────────
# Get your key at https://agentverse.ai
AGENTVERSE_API_KEY=your_agentverse_api_key_here

# ── Agent seeds (keep secret — used to derive stable agent addresses) ─────────
ORCHESTRATOR_SEED=your_orchestrator_seed_here
TRANSCRIPT_SEED=your_transcript_agent_seed_here
LOCATION_SEED=your_location_extractor_seed_here
GEOCODER_SEED=your_geocoder_mapper_seed_here
TRIP_PLANNER_SEED=your_trip_planner_seed_here
WEATHER_SEED=your_weather_monitor_seed_here
PDF_SEED=your_pdf_generator_seed_here
EXCEL_SEED=your_excel_generator_seed_here
AGGREGATOR_SEED=your_aggregator_seed_here

# ── Sub-agent addresses (fill in after first run) ─────────────────────────────
# Each agent prints its address on startup — copy them here.
TRANSCRIPT_AGENT_ADDR=
LOCATION_AGENT_ADDR=
GEOCODER_AGENT_ADDR=
TRIP_PLANNER_AGENT_ADDR=
WEATHER_AGENT_ADDR=
PDF_AGENT_ADDR=
EXCEL_AGENT_ADDR=
AGGREGATOR_AGENT_ADDR=

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Get test keys at https://dashboard.stripe.com/apikeys
# Leave STRIPE_SECRET_KEY blank to disable the payment gate (free/dev mode).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_PRICE_CENTS=299
STRIPE_CURRENCY=usd
STRIPE_PRODUCT_NAME=Travel Map Agent - Trip Plan
STRIPE_SUCCESS_URL=https://asi1.ai
STRIPE_CHECKOUT_EXPIRES_SECONDS=1800
