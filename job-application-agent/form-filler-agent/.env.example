# Form-Filler Agent env vars.
# Sensitive vars (AGENTVERSE_API_KEY, ASI_ONE_API_KEY) live in the repo-root
# .env and are loaded automatically.

FORM_FILLER_AGENT_SEED=form-filler-agent-user-facing-seed-v1
FORM_FILLER_AGENT_PORT=8013

# Addresses of the three helper agents. Get these from each helper's
# startup log (printed as "Agent starting: ... at agent1q...").
EXTRACTOR_AGENT_ADDRESS=
PROFILE_AGENT_ADDRESS=
SUBMITTER_AGENT_ADDRESS=

# user_key passed to the profile agent. Use a stable string so the same
# stored profile is reused across sessions.
DEFAULT_USER_KEY=me

# Default resume path used when submitting. If empty, the profile agent's
# stored resume path is read from the profile and used. Most users won't
# need to override this.
DEFAULT_RESUME_PATH=

# Per-agent send_and_receive timeouts (seconds).
EXTRACTOR_TIMEOUT=30
PROFILE_TIMEOUT=90
SUBMITTER_TIMEOUT=60
