# Orchestrator Agent env vars.
# Sensitive vars (AGENTVERSE_API_KEY, ASI_ONE_API_KEY) live in the repo-root
# .env and are loaded automatically.

ORCHESTRATOR_AGENT_SEED=orchestrator-agent-user-facing-seed-v1
ORCHESTRATOR_AGENT_PORT=8014

# Addresses of the helper agents. Get these from each helper's
# startup log (printed as "Agent starting: ... at agent1q...").
PROFILE_AGENT_ADDRESS=
FORM_FILLER_AGENT_ADDRESS=

# user_key passed to the profile agent. Use a stable string so the same
# stored profile is reused across sessions. (Multi-user support derives
# this from sender address — not implemented yet.)
DEFAULT_USER_KEY=me

# Per-agent send_and_receive timeouts (seconds).
PROFILE_TIMEOUT=30
INGEST_TIMEOUT=120
