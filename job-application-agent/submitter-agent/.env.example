# Submitter Agent — env vars (copy into repo-root .env)

# Deterministic seed so the agent address stays stable across restarts.
SUBMITTER_AGENT_SEED=submitter-agent-helper-seed-v1

# Port the local uAgent listens on (avoid clashing with extractor:8010 / profile:8011).
SUBMITTER_AGENT_PORT=8012

# If "1" / "true", every submission is treated as a dry-run regardless of
# what the caller sets. Useful for local development against real boards.
SUBMITTER_DEFAULT_DRY_RUN=0

# Required for Agentverse mailbox + chat registration (shared across agents).
AGENTVERSE_API_KEY=
