# OpenAI
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ASI1 / Fetch.ai LLM
# Get your API key from: https://asi1.ai/
ASI1_API_KEY=your-asi1-api-key-here
ASI_ONE_API_KEY=your-asi-one-api-key-here

# Agentverse / Fetch.ai
# Get your API key from: https://agentverse.ai/
AGENTVERSE_API_TOKEN=your-agentverse-api-token-here
AGENTVERSE_URL=https://agentverse.ai

# Stripe
# Get your API keys from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_PRODUCT_NAME=Service
STRIPE_AMOUNT_CENTS=1000
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:8000/success
STRIPE_CHECKOUT_EXPIRES_SECONDS=1800

# Repliers API (conversational-property-finder only)
# Get your API key from: https://repliers.io/
REPLIERS_API_KEY=your-repliers-api-key-here

# Email (conversational-property-finder only)
EMAIL_API_KEY=your-email-api-key-here
EMAIL_TO=your-email@example.com

# Agent Configuration
AGENT_SEED=your-agent-seed-phrase-here
AGENT_PORT=8000
AGENT_ENDPOINT_URL=http://localhost:8000
AGENT_SECRET_KEY_1=your-agent-secret-key-here
USE_MAILBOX=true

# YouTube Growth Analyzer Configuration
RECENT_VIDEO_MAX_RESULTS=10
PREMIUM_REPORT_CHUNK_CHARS=2000
PAYMENT_DEADLINE_SECONDS=300
STATE_TTL_SECONDS=3600
LOG_LEVEL=INFO
LOG_MAILBOX_HELP=true
MAILBOX_CONNECT_RETRIES=3
MAILBOX_CONNECT_DELAY_SECONDS=5
MAILBOX_CONNECT_RETRY_INTERVAL=10
