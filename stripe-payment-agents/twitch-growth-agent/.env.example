# Copy to .env and fill in your own keys. Do NOT commit the real .env.

# ASI:One (OpenAI-compatible LLM). Get a key at https://asi1.ai
ASI_ONE_API_KEY=your_asi_one_api_key

# Tavily web search. Get a key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key

# Twitch app credentials. Register an app at https://dev.twitch.tv/console/apps
# Use a CONFIDENTIAL client with the Authorization Code grant (gives refresh tokens).
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Multi-user Twitch OAuth (per-user tokens, Authorization Code grant).
# Must match the redirect URL registered in the Twitch console CHARACTER FOR
# CHARACTER. For local dev, point ngrok at OAUTH_CALLBACK_PORT and use the ngrok
# HTTPS URL here (e.g. https://<sub>.ngrok-free.app/callback).
TWITCH_REDIRECT_URI=http://localhost:3000/callback
# Local port the callback server binds to (ngrok forwards to this).
OAUTH_CALLBACK_PORT=3000
# Random secret used to sign the OAuth `state` value (any long random string).
OAUTH_STATE_SECRET=generate_a_long_random_string
# Random secret used to encrypt tokens at rest (any long random string).
TOKEN_ENCRYPTION_KEY=generate_a_long_random_string
# Path to the SQLite token store (created automatically).
TOKEN_DB_PATH=twitchy_tokens.db

# Stripe payments (full report is gated behind a $1 embedded Stripe checkout
# that renders inside the ASI:One chat).
# Get keys at https://dashboard.stripe.com/apikeys (use test keys for testing).
STRIPE_SECRET_KEY=
# Publishable key is required to mount the embedded card in the chat.
STRIPE_PUBLISHABLE_KEY=
# Optional: return_url for the embedded checkout (completion stays in-chat).
STRIPE_SUCCESS_URL=https://example.com/success
# Optional: override the price in cents (default 100 = $1.00).
STRIPE_AMOUNT_CENTS=100

# Optional: fixed seed phrase for a stable uAgent identity/address (Agentverse)
AGENT_SEED=your_agent_seed
