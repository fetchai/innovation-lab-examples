# Copy to .env and fill in values:  cp .env.example .env

# Required — YouTube Data API v3
YOUTUBE_API_KEY=

# Required — Stripe (test keys for development)
# https://docs.stripe.com/keys
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_

# Embedded Checkout return_url base (Stripe appends session_id)
STRIPE_SUCCESS_URL=https://example.com/stripe-return

# Lowercase ISO currency (e.g. usd)
STRIPE_CURRENCY=usd

# Agent networking (match docker-compose host port if using Docker)
AGENT_PORT=8012

# Agentverse / ASI:One — mailbox (strongly recommended for remote chat)
# Get token from Agentverse profile (same as Inspector → Connect → Mailbox).
AGENTVERSE_API_TOKEN=

# Mailbox mode: true = Agentverse delivers to your agent via mailbox
USE_MAILBOX=true
