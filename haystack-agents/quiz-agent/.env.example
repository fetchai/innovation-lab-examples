# Fetch.ai / Agentverse
# Agentverse API key (https://agentverse.ai/profile/api-keys) — optional for
# local runs, required if you register/publish from a script.
AGENTVERSE_API_KEY=your_agentverse_api_key_here

# A unique, random string. Determines the agent's permanent address. Do NOT
# reuse another agent's seed (it would collide on the Almanac).
AGENT_SEED=replace_with_a_unique_random_seed_phrase
AGENT_NAME=haystack-quiz-agent
AGENT_PORT=8080


# ASI:One LLM — used by Haystack to generate quiz questions
# Get a key at https://asi1.ai/dashboard/api-keys
ASI1_API_KEY=your_asi1_api_key_here
ASI1_MODEL=asi1            # or asi1-mini for lower cost


# OpenAI — used by Haystack for embeddings (RAG retrieval + citations)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBED_MODEL=text-embedding-3-small

# Stripe: embedded Checkout behind the Fetch payment protocol
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_AMOUNT_CENTS=200            # $2.00
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://agentverse.ai
STRIPE_CHECKOUT_EXPIRES_SECONDS=1800
