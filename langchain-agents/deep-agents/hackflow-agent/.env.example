# Python version 
# Requires Python 3.11 or higher. deepagents will not install on 3.10.
# LLM Provider (at least one required)

# Option A: ASI:One (preferred Fetch.ai own model)
ASI1_API_KEY=your_asi1_api_key_here

# Option B: Anthropic Claude (fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fetch.ai Agent
# Get from: agentverse.ai -> Settings -> API Keys
AGENTVERSE_API_KEY=your_agentverse_api_key_here

# Any passphrase to generate your agent wallet address. Keep secret.
AGENT_SEED=replace_this_with_any_random_passphrase
AGENT_NAME=hackflow-competitive-intel
AGENT_PORT=8008

# Payment : Using Stripe embedded Checkout (renders card form inside ASI:One chat)
# Get test keys from: dashboard.stripe.com -> Developers -> API keys
# Test card: 4242 4242 4242 4242, any future expiry, any CVC
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_AMOUNT_CENTS=100         # 100 = $1.00
STRIPE_CURRENCY=usd
# STRIPE_SUCCESS_URL=https://agentverse.ai  # optional, defaults to agentverse.ai

# Search : Using Tavily API (free key at: https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here