# ── Vision LLM (pick ONE — Gemini is free, OpenAI is the paid alternative) ───
# VISION_PROVIDER: auto | gemini | openai   ("auto" prefers Gemini if key present)
VISION_PROVIDER=auto

# Gemini Flash — FREE tier (1500 req/day, no billing needed)
# Get key instantly at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI GPT-4o — optional fallback (~$0.005/image, paid only)
OPENAI_API_KEY=

# ── Bright Data Web Unlocker ──────────────────────────────────────────────────
# Find these at: https://brightdata.com/cp/zones
# Proxy URL built as: brd-customer-{CUSTOMER_ID}-zone-{ZONE}:{TOKEN}@brd.superproxy.io:22225
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=web_unlocker1

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Enable "YouTube Data API v3" in Google Cloud Console → create an API key
YOUTUBE_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Fetch.ai uAgents — diagnostic bureau ─────────────────────────────────────
# Mailbox mode (Render → Agentverse): leave AGENT_ENDPOINT blank; set AGENTVERSE_API_KEY.
# Direct endpoint mode: set AGENT_ENDPOINT=https://<your-public-host>  (disables mailbox).
AGENT_NETWORK=testnet
AGENT_ENDPOINT=
AGENTVERSE_API_KEY=

# Bureau listens on BUREAU_PORT locally; Render overrides this with its own PORT.
BUREAU_PORT=8000

# Stable seeds → deterministic agent addresses.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ORCHESTRATOR_AGENT_SEED=
ORCHESTRATOR_AGENT_PORT=8001
PARTS_AGENT_SEED=
PARTS_AGENT_PORT=8002
# Docker multi-container: set to the Compose service name so the Almanac
# endpoint resolves correctly between containers. Leave blank for local (127.0.0.1).
PARTS_AGENT_HOST=
TUTORIAL_AGENT_SEED=
TUTORIAL_AGENT_PORT=8003
TUTORIAL_AGENT_HOST=

# How long the orchestrator waits for worker responses before falling back to
# direct service calls.
# With Agentverse mailbox round-trips (~10-20s each direction) + Bright Data
# scraping (~30-40s), 120s is the safe default.  Lower to 30 in Docker direct
# mode where workers are reachable without Agentverse relay.
WORKER_TIMEOUT_S=120

# Single-container bureau mode: seconds to wait after starting worker processes
# before launching the orchestrator (allows workers to register on Almanac).
WORKER_READY_WAIT=8
