# ── Common settings for job-application-agent ─────────────────────────────────
# Copy this file to .env and fill in your values.

# ASI:One LLM
ASI_ONE_API_KEY=
ASI_ONE_CHAT_MODEL=asi1

# Agentverse registration
AGENTVERSE_API_KEY=

# Default key for profile/session storage
DEFAULT_USER_KEY=me

# Agent identity
ORCHESTRATOR_AGENT_SEED=orchestrator-agent-user-facing-seed-v1
ORCHESTRATOR_AGENT_PORT=8014

# Resume + form fill
DEFAULT_RESUME_PATH=
LIVE_FILL_MODE=headed
LIVE_FILL_SCREENSHOT_EVERY=3
SUBMITTER_DEFAULT_DRY_RUN=0

# Payment gate (Stripe)
# Set PAYMENT_ENABLED=true and fill in Stripe keys to charge per application.
PAYMENT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_AMOUNT_CENTS=100
STRIPE_CURRENCY=usd
STRIPE_PRODUCT_NAME=Job Application Service
STRIPE_SUCCESS_URL=https://agentverse.ai/payment-success
